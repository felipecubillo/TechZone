<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
 </configSections>
 <connectionStrings>
  <add name="AppProyectoFelipe.Properties.Settings.Cadena" connectionString="Data Source=LENOVOFELIPE\MSSQLSERVER1;Initial Catalog=DBTechZone;Persist Security Info=True;User ID=sa;Password=123456;Encrypt=False;TrustServerCertificate=True"
   providerName="System.Data.SqlClient" />
 </connectionStrings>
 <appSettings>
		<add key="NombreEmpresa" value="UTN Company." />
		<add key="URLPadron" value="https://api.hacienda.go.cr/fe/ae?identificacion=" />
		<add key="URLProvincia" value="https://raw.githubusercontent.com/lateraluz/Datos/master/provincias.json" />
	</appSettings>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="wsindicadoreseconomicosSoap">
                    <security mode="Transport" />
                </binding>
                <binding name="wsindicadoreseconomicosSoap1" />
            </basicHttpBinding>
            <customBinding>
                <binding name="wsindicadoreseconomicosSoap12">
                    <textMessageEncoding messageVersion="Soap12" />
                    <httpsTransport />
                </binding>
            </customBinding>
        </bindings>
        <client>
            <endpoint address="https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx"
                binding="basicHttpBinding" bindingConfiguration="wsindicadoreseconomicosSoap"
                contract="ServiceBCCR.wsindicadoreseconomicosSoap" name="wsindicadoreseconomicosSoap" />
            <endpoint address="https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx"
                binding="customBinding" bindingConfiguration="wsindicadoreseconomicosSoap12"
                contract="ServiceBCCR.wsindicadoreseconomicosSoap" name="wsindicadoreseconomicosSoap12" />
        </client>
    </system.serviceModel>
</configuration>